{
  "$schema": "https://json-schema.org/schema",
  "version": 2,
  "title": "Varlock scan executor",
  "description": "Runs `varlock scan` to detect plaintext secrets. Useful in CI and as a pre-commit hook.",
  "type": "object",
  "properties": {
    "staged": {
      "type": "boolean",
      "description": "Only scan git-staged files (--staged)."
    },
    "includeIgnored": {
      "type": "boolean",
      "description": "Include .gitignore-listed files in the scan (--include-ignored)."
    },
    "path": {
      "type": "string",
      "description": "Schema entry point (--path)."
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit file paths or globs to scan."
    }
  },
  "required": []
}
